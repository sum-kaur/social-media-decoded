# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media_decoded
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=social_media_decoded

# App
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000

# Embeddings
EMBEDDING_MODEL=voyage-3
EMBEDDING_BATCH_SIZE=96

# LLM
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# Cache (Redis in prod, in-memory dict in dev)
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
